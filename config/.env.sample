# =============================================================================
# MLCC Graph POC - environment template
# Copy to `config/.env` and fill in values. This file is checked in; .env is not.
# =============================================================================

# -----------------------------------------------------------------------------
# Apache AGE / PostgreSQL (shared by all pipelines)
# -----------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=lightrag
POSTGRES_PASSWORD=lightrag
POSTGRES_DATABASE=lightrag_db
POSTGRES_MAX_CONNECTIONS=12

# LightRAG storage class names. PGGraphStorage = Apache AGE.
#
# NOTE on vector storage: the bundled `apache/age:PG16_latest` image does NOT
# ship pgvector. `sql/init_pgvector.sql` only creates the extension if the
# server has it, so the default below is `NanoVectorDBStorage` (file-backed,
# always works). If you swap the image for one that bundles pgvector
# (e.g. `pgvector/pgvector:pg16` + AGE built in, or your own), set:
#     LIGHTRAG_VECTOR_STORAGE=PGVectorStorage
# AND make sure CREATE EXTENSION vector succeeds on first boot.
LIGHTRAG_KV_STORAGE=PGKVStorage
LIGHTRAG_VECTOR_STORAGE=NanoVectorDBStorage
LIGHTRAG_GRAPH_STORAGE=PGGraphStorage
LIGHTRAG_DOC_STATUS_STORAGE=PGDocStatusStorage

# AGE graph name is derived from POSTGRES_WORKSPACE per process.
# The pipeline runners set this themselves - do NOT set it globally.
# POSTGRES_WORKSPACE=mlcc_graphify_to_lightrag
# POSTGRES_WORKSPACE=mlcc_lightrag_only

# -----------------------------------------------------------------------------
# Local LLM via LiteLLM (shared by ALL pipelines, including KG extraction)
#
# We use LiteLLM as the single client so we don't have to special-case
# Ollama vs vLLM vs LocalAI. Pick a model string in LiteLLM's format
# ('<provider>/<model>') and point base_url at your local server.
#
# Examples:
#
#   # vLLM (OpenAI-compatible, runs at /v1)
#   LLM_MODEL=openai/Qwen2.5-32B-Instruct
#   LLM_BINDING_HOST=http://localhost:8000/v1
#
#   # Ollama
#   LLM_MODEL=ollama/llama3:70b
#   LLM_BINDING_HOST=http://localhost:11434
#
#   # LiteLLM proxy (centralizes auth + rate limiting)
#   LLM_MODEL=openai/qwen-32b   # alias defined in your litellm config
#   LLM_BINDING_HOST=http://localhost:4000
# -----------------------------------------------------------------------------

# --- Completion model ---
LLM_MODEL=ollama/llama3
LLM_BINDING_HOST=http://localhost:11434
LLM_BINDING_API_KEY=sk-local-placeholder        # most local servers ignore, but must be set
LLM_TIMEOUT=240
LLM_MAX_ASYNC=4                                  # concurrent requests LightRAG issues

# --- Embedding model ---
EMBEDDING_MODEL=ollama/bge-m3
EMBEDDING_BINDING_HOST=http://localhost:11434
EMBEDDING_BINDING_API_KEY=sk-local-placeholder
EMBEDDING_DIM=1024                               # MUST match the model's output dim
EMBEDDING_MAX_ASYNC=8
EMBEDDING_MAX_TOKEN_SIZE=8192

# LightRAG config knobs that affect KG quality.
LIGHTRAG_MAX_ENTITY_TOKENS=6000
LIGHTRAG_CHUNK_TOKEN_SIZE=1200
LIGHTRAG_CHUNK_OVERLAP_TOKEN_SIZE=100
LIGHTRAG_ENTITY_EXTRACT_MAX_GLEANING=1

# -----------------------------------------------------------------------------
# Pipeline A KG extractor (LiteLLM-based; replaces Graphify host-agent)
#
# The extractor batches preprocessed facts and asks the LLM for a JSON KG.
# Tune for your model's context window and concurrency limits.
# -----------------------------------------------------------------------------
KG_BATCH_SIZE=20
KG_MAX_CONCURRENCY=4
GRAPHIFY_OUT_DIR=output/graphify_to_lightrag/graphify_raw

# -----------------------------------------------------------------------------
# Pipeline bridge knobs
# -----------------------------------------------------------------------------
MIN_EDGE_CONFIDENCE=0.3        # drop low-confidence edges in bridge.py
