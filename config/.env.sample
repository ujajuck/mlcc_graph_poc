# =============================================================================
# MLCC Graph POC - environment template
# Copy to `config/.env` and fill in values. This file is checked in; .env is not.
# =============================================================================

# -----------------------------------------------------------------------------
# Apache AGE / PostgreSQL (shared by both pipelines)
# -----------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=lightrag
POSTGRES_PASSWORD=lightrag
POSTGRES_DATABASE=lightrag_db
POSTGRES_MAX_CONNECTIONS=12

# LightRAG storage class names. PGGraphStorage = Apache AGE.
LIGHTRAG_KV_STORAGE=PGKVStorage
LIGHTRAG_VECTOR_STORAGE=PGVectorStorage
LIGHTRAG_GRAPH_STORAGE=PGGraphStorage
LIGHTRAG_DOC_STATUS_STORAGE=PGDocStatusStorage

# AGE graph name is derived from POSTGRES_WORKSPACE per process.
# The pipeline runners set this themselves - do NOT set it globally.
# POSTGRES_WORKSPACE=mlcc_graphify_to_lightrag
# POSTGRES_WORKSPACE=mlcc_lightrag_only

# -----------------------------------------------------------------------------
# Local LLM server (shared by both pipelines)
#
# Both pipelines target the same locally-served, OpenAI-compatible LLM
# endpoint. Works with vLLM, Ollama (with `/v1` compat layer), LocalAI,
# text-generation-webui's OpenAI extension, TGI, llama.cpp --api, etc.
#
# Pipeline B (LightRAG) reads LLM_* / EMBEDDING_* directly via the OpenAI
# binding. Pipeline A (Graphify) does NOT make HTTP calls itself - the host
# coding agent does (see README "Graphify host agent setup"). Set the same
# values in that host agent's config so both sides hit the same model.
# -----------------------------------------------------------------------------

# --- Completion model ---
LLM_BINDING=openai                         # openai | azure | ollama | ...
LLM_MODEL=Qwen2.5-32B-Instruct             # whatever your local server serves
LLM_BINDING_HOST=http://localhost:8000/v1  # vLLM default
LLM_BINDING_API_KEY=sk-local-placeholder   # most local servers ignore, but must be set
LLM_TIMEOUT=240
LLM_MAX_ASYNC=4                            # concurrent requests LightRAG issues

# --- Embedding model ---
EMBEDDING_BINDING=openai
EMBEDDING_MODEL=bge-m3
EMBEDDING_DIM=1024                         # MUST match the model's output dim
EMBEDDING_BINDING_HOST=http://localhost:8001/v1
EMBEDDING_BINDING_API_KEY=sk-local-placeholder
EMBEDDING_MAX_ASYNC=8

# LightRAG config knobs that affect KG quality.
LIGHTRAG_MAX_ENTITY_TOKENS=6000
LIGHTRAG_CHUNK_TOKEN_SIZE=1200
LIGHTRAG_CHUNK_OVERLAP_TOKEN_SIZE=100
LIGHTRAG_ENTITY_EXTRACT_MAX_GLEANING=1

# -----------------------------------------------------------------------------
# Graphify (pipeline A only)
#
# Graphify is a "skill" that runs inside a host coding agent. For a local LLM
# setup the host agent must route to our local server. Recommended hosts:
#
#   - OpenCode   (https://opencode.ai) - native OpenAI-compatible config
#   - Aider      (https://aider.chat)  - use --openai-api-base
#
# See README for exact install commands per host. The env vars below are used
# by the wrapper in pipeline/graphify_to_lightrag/run_graphify.py.
# -----------------------------------------------------------------------------
GRAPHIFY_CMD=graphify                              # CLI name on PATH
GRAPHIFY_HOST_AGENT=opencode                       # opencode | aider | claude | codex | ...
GRAPHIFY_OUT_DIR=output/graphify_to_lightrag/graphify_raw
GRAPHIFY_MODE=deep                                 # deep | fast
GRAPHIFY_DIRECTED=1                                # preserve edge direction

# Forwarded to the host agent so it hits the *same* local LLM as pipeline B.
# These are re-exported by the pipeline A runner with names the host expects.
GRAPHIFY_LLM_BASE_URL=${LLM_BINDING_HOST}
GRAPHIFY_LLM_API_KEY=${LLM_BINDING_API_KEY}
GRAPHIFY_LLM_MODEL=${LLM_MODEL}

# -----------------------------------------------------------------------------
# Pipeline bridge knobs
# -----------------------------------------------------------------------------
MIN_EDGE_CONFIDENCE=0.3        # drop INFERRED edges below this in bridge.py
