# Apache AGE / PostgreSQL - shared graph substrate for both pipelines.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=lightrag
POSTGRES_PASSWORD=lightrag
POSTGRES_DATABASE=lightrag_db
POSTGRES_MAX_CONNECTIONS=12

# LightRAG storage backends. PGGraphStorage = Apache AGE.
LIGHTRAG_KV_STORAGE=PGKVStorage
LIGHTRAG_VECTOR_STORAGE=PGVectorStorage
LIGHTRAG_GRAPH_STORAGE=PGGraphStorage
LIGHTRAG_DOC_STATUS_STORAGE=PGDocStatusStorage

# AGE graph name is derived from POSTGRES_WORKSPACE by PGGraphStorage.
# The two pipelines MUST use different workspaces so their graphs are isolated.
# These are set per-run by the pipeline scripts - do not set a global value here.
# POSTGRES_WORKSPACE=mlcc_graphify_to_lightrag   # set by pipeline A
# POSTGRES_WORKSPACE=mlcc_lightrag_only          # set by pipeline B

# LLM / embedding configuration for LightRAG.
# Swap these for your provider of choice; LightRAG accepts OpenAI-compatible
# endpoints so vLLM / Ollama / Azure also work.
LLM_BINDING=openai
LLM_MODEL=gpt-4o-mini
LLM_BINDING_HOST=https://api.openai.com/v1
LLM_BINDING_API_KEY=

EMBEDDING_BINDING=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536
EMBEDDING_BINDING_HOST=https://api.openai.com/v1
EMBEDDING_BINDING_API_KEY=

# Graphify CLI - used only by pipeline A.
# Install once with: uv tool install graphifyy && graphify install
GRAPHIFY_CMD=graphify
GRAPHIFY_OUT_DIR=output/graphify_to_lightrag/graphify_raw
